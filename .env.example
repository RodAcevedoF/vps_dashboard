# Dashboard Authentication
DASHBOARD_TOKEN=your-secret-token-here

# Redis Configuration
REDIS_HOST=sagepoint_redis
REDIS_PORT=6379

# PostgreSQL Configuration
DATABASE_URL=postgresql://user:password@sagepoint_postgres:5432/dbname
POSTGRES_HOST=sagepoint_postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_DB=postgres

# Neo4j Configuration
NEO4J_URI=bolt://sagepoint_neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# API Endpoints
PROD_API_URL=http://sagepoint_api:3001
STAGING_API_URL=http://sagepoint_api_staging:3002

# Server Configuration
PORT=3010
NODE_ENV=development
